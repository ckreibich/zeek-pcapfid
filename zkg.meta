[package]
script_dir = scripts
build_command = ./configure && cmake --build build
summary = Dummy implementation of a Packet-deriving packet source.
description = Provides a packet source that derives a custom Packet
	class and uses it in returned packets.

[template]
source = https://github.com/zeek/package-template
version = v3.1.8
zkg_version = 3.1.0-13
features = plugin

[template_vars]
name = PcapFIDSource
namespace = Corelight
